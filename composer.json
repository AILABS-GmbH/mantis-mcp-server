{
    "name": "ailabs/mantis-mcp-server",
    "description": "A secure, file-logged MCP server (Streamable HTTP) for the MantisBT bug tracker.",
    "type": "project",
    "license": "MIT",
    "keywords": ["mcp", "model-context-protocol", "mantis", "mantisbt", "bug-tracker", "llm"],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "MantisMcp\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "serve": "php -d display_errors=0 -S 127.0.0.1:8088 -t public",
        "lint": "find src public config -name '*.php' -print0 | xargs -0 -n1 php -l"
    }
}
