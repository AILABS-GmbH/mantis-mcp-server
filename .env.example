# ---------------------------------------------------------------------------
# Mantis MCP Server - example configuration
# Copy to ".env" and adjust the values. The .env file is NOT committed.
# ---------------------------------------------------------------------------

# Base URL of the Mantis installation (without trailing slash).
# The REST endpoint /api/rest is appended automatically by the client.
MANTIS_BASE_URL="https://mantis.example.com"

# Personal API token from Mantis (My Account -> API Tokens).
MANTIS_API_TOKEN="changeme-mantis-api-token"

# Verify the TLS certificate of the Mantis instance (keep true in production!).
MANTIS_VERIFY_TLS="true"

# Optional path to a CA bundle, e.g. when using an internal certificate.
# MANTIS_CA_BUNDLE="/etc/ssl/certs/internal-ca.pem"

# Connection and total request timeouts in seconds.
MANTIS_CONNECT_TIMEOUT="5"
MANTIS_TIMEOUT="30"

# --- Impersonation (act on behalf of a specific Mantis user) ---------------
# The MantisBT REST API does NOT support HTTP Basic Auth. Instead, a token
# whose owner has sufficient access (impersonate_user_threshold, typically an
# administrator) can act as another user via the "Mantis-Username" header.
#
# When enabled, the target user is read from the incoming "X-Mantis-User"
# request header (falling back to MANTIS_DEFAULT_USER). The impersonated
# user's password is NOT required.
MANTIS_IMPERSONATION_ENABLED="false"

# Optional fallback user when no X-Mantis-User header is sent.
# MANTIS_DEFAULT_USER=""

# ---------------------------------------------------------------------------
# MCP server
# ---------------------------------------------------------------------------

# Optional bearer token that MCP clients must send in the Authorization header.
# Leave empty to disable access control on the MCP endpoint (e.g. when access
# is already restricted by a reverse proxy / VPN).
MCP_AUTH_TOKEN=""

# Comma-separated list of allowed Origin headers (DNS-rebinding protection).
# Empty = origin check disabled.
MCP_ALLOWED_ORIGINS=""

# Lifetime of an MCP session in seconds (inactivity).
MCP_SESSION_TTL="3600"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: debug | info | notice | warning | error | critical
LOG_LEVEL="info"

# Directory for log files (relative to the project root, or absolute).
LOG_DIR="logs"
