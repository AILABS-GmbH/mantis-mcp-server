# Mantis MCP Extension — Apache configuration
#
# 1) Route everything to index.php (the endpoint is the folder itself).
# 2) Forward the Authorization header to PHP. Under CGI/FastCGI (common on
#    managed hosting) Apache strips it by default; the rewrite rule below
#    re-exposes it as the HTTP_AUTHORIZATION environment variable, and
#    CGIPassAuth covers newer Apache versions.
# 3) Deny direct web access to the lib/ and logs/ directories.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forward Basic Auth credentials to PHP (CGI/FastCGI setups).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Block direct access to internals.
    RewriteRule ^(lib|logs)(/|$) - [F,L]

    # Everything else goes to the entry point.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Apache >= 2.4.13: pass Authorization to CGI/FastCGI directly.
<IfVersion >= 2.4.13>
    CGIPassAuth On
</IfVersion>
